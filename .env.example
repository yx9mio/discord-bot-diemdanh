# Discord
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# App
NODE_ENV=development
# LOG_LEVEL: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Sentry (optional, bỏ trống để tắt)
# Lấy DSN tại: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# Datadog APM + Logs (optional, bỏ trống để tắt hoàn toàn)
# Lấy API key tại: https://app.datadoghq.com → Organization Settings → API Keys
DD_API_KEY=
DD_SITE=ap1.datadoghq.com
DD_SERVICE=discord-bot-diemdanh
DD_ENV=production
