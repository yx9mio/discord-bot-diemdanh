# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=token_bot_cua_ban
CLIENT_ID=application_id_cua_ban

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://rtvnogxasuswfnugcoyr.supabase.co
SUPABASE_KEY=anon_key_lay_tu_supabase_dashboard

# ── Grafana Cloud Loki (tuỳ chọn — bỏ trống để tắt) ─────────────────────────
# Lấy ở: grafana.com → My Account → stack của bạn → "Send logs" → Loki
# LOKI_URL   : copy từ mục "URL"  (dạng https://logs-prod-xxx.grafana.net)
# LOKI_USER  : copy từ mục "User" (số nguyên, VD: 123456)
# LOKI_TOKEN : tạo API token scope "logs:write" ở grafana.com → API Keys
LOKI_URL=
LOKI_USER=
LOKI_TOKEN=

# Tuỳ chọn — để mặc định cũng được
LOKI_SERVICE=discord-bot-diemdanh
LOKI_ENV=production
# LOKI_FLUSH_INTERVAL=5000   # ms giữa 2 lần flush (default 5000)
# LOKI_BATCH_MAX=100         # max entries mỗi batch   (default 100)

# ── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warn | error  (default: info)
# LOG_LEVEL=info
