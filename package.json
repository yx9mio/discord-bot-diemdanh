{
  "name": "discord-bot-diemdanh",
  "version": "3.0.0",
  "private": true,
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "reload": "node -e \"process.exit(0)\"",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:pull": "supabase db pull",
    "supabase:types": "supabase gen types typescript --local > supabase/types.ts",
    "supabase:remote-types": "supabase gen types typescript --linked > supabase/types.ts",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset"
  },
  "dependencies": {
    "@sapphire/framework": "^5.3.4",
    "@sapphire/plugin-logger": "^4.0.2",
    "@sapphire/plugin-subcommands": "^7.0.1",
    "@supabase/supabase-js": "^2.49.4",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "luxon": "^3.5.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "eslint": "^9.27.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "supabase": "^2.105.0"
  }
}
