{
  "name": "discord-bot-diemdanh",
  "version": "3.0.0",
  "description": "Bot Discord điểm danh — Sapphire JS Edition",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.js": ["eslint --fix", "eslint"]
  },
  "dependencies": {
    "@sapphire/framework": "^5.3.4",
    "@sapphire/plugin-logger": "^4.0.2",
    "@sapphire/plugin-subcommands": "^7.0.1",
    "@sapphire/utilities": "^3.17.0",
    "@sapphire/discord.js-utilities": "^7.3.1",
    "@sentry/node": "^8.47.0",
    "@supabase/supabase-js": "^2.49.4",
    "croner": "^9.0.0",
    "csv-stringify": "^6.5.2",
    "date-fns-tz": "^3.2.0",
    "dd-trace": "^5.40.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "luxon": "^3.5.0",
    "p-queue": "^8.1.0",
    "p-retry": "^6.2.1",
    "pino": "^9.6.0",
    "pino-datadog-transport": "^1.1.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "eslint-plugin-n": "^17.18.0",
    "lint-staged": "^15.5.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "simple-git-hooks": "^2.11.1",
    "vitest": "^3.2.0"
  }
}
